{
  "expo": {
    "name": "FNS",
    "slug": "fns-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fnewsteer",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0b"
      },
      "package": "com.tushcmd.fns",
      "permissions": ["RECEIVE_BOOT_COMPLETED", "VIBRATE", "POST_NOTIFICATIONS"]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#f59e0b",
          "defaultChannel": "fns"
        }
      ],
      "expo-secure-store",
      "expo-status-bar",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "FNSStatus",
              "label": "FNS Status",
              "description": "Shows your top pair CLEAR/BLOCKED status at a glance",
              "minWidth": "320dp",
              "minHeight": "120dp",
              "targetCellWidth": 5,
              "targetCellHeight": 2,
              "previewImage": "./assets/widget-preview/fns-status.png",
              "updatePeriodMillis": 1800000,
              "widgetFeatures": "reconfigurable"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c00d92c9-3edb-40e0-8530-47cf16aef9d5"
      }
    }
  }
}
